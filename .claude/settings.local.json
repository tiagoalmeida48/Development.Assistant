{
  "permissions": {
    "allow": [
      "Bash(dotnet add package:*)",
      "WebSearch",
      "Bash(yarn build)",
      "Bash(yarn install:*)",
      "Bash(yarn dev)",
      "Bash(yarn list:*)",
      "WebFetch(domain:tanstack.com)",
      "Bash(dotnet build:*)",
      "Bash(yarn add:*)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(rm:*)",
      "Read(//usr/**)",
      "Bash(test:*)",
      "Bash(du:*)",
      "Bash(dotnet msbuild:*)",
      "Bash(dotnet clean:*)",
      "Bash(npm run build:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/skills/impeccable/scripts/hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking UI changes"
          }
        ]
      }
    ]
  },
  "description": "Impeccable design detector: runs after Edit/Write/MultiEdit on UI files and surfaces findings as system reminders."
}
