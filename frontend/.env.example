# ==========================================
# Development Assistant - Frontend Config
# ==========================================

# GraphQL API URL
#
# Desenvolvimento local (com proxy do Vite):
# VITE_GRAPHQL_URL=/graphql
#
# Desenvolvimento local (conexão direta HTTP):
# VITE_GRAPHQL_URL=http://localhost:5000/graphql
#
# Desenvolvimento local (HTTPS):
# VITE_GRAPHQL_URL=https://localhost:44304/graphql
#
# Produção (path relativo - recomendado):
# VITE_GRAPHQL_URL=/graphql
#
# O valor padrão se não especificado é /graphql
VITE_GRAPHQL_URL=/graphql
